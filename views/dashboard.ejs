<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:Arial, sans-serif;
    background:#f4f6f9;
}

.navbar{
    background:#009688;
    color:white;
    padding:15px 40px;
    display:flex;
    justify-content:space-between;
    align-items:center;
}

.navbar a{
    color:white;
    text-decoration:none;
    background:red;
    padding:8px 15px;
    border-radius:6px;
}

.container{
    width:90%;
    margin:auto;
    margin-top:30px;
}

.welcome{
    margin-bottom:25px;
}

.cards{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:20px;
}

.card{
    background:white;
    padding:25px;
    border-radius:10px;
    box-shadow:0 4px 10px rgba(0,0,0,0.1);
    text-align:center;
}

.card h3{
    margin-bottom:10px;
    color:#333;
}

.card p{
    font-size:28px;
    color:#009688;
    font-weight:bold;
}

.profile{
    margin-top:40px;
    background:white;
    padding:25px;
    border-radius:10px;
    box-shadow:0 4px 10px rgba(0,0,0,0.1);
}

.profile h2{
    margin-bottom:15px;
}

.profile p{
    margin:10px 0;
    font-size:18px;
}
</style>
</head>

<body>

<div class="navbar">
    <h2>Dashboard</h2>
    <a href="/login">Logout</a>
</div>

<div class="container">

<div class="welcome">
    <h1>Welcome User 👋</h1>
    <p>Login Successfully</p>
</div>

<div class="cards">

<div class="card">
    <h3>Total Users</h3>
    <p>150</p>
</div>

<div class="card">
    <h3>Total Orders</h3>
    <p>75</p>
</div>

<div class="card">
    <h3>Total Revenue</h3>
    <p>₹25,000</p>
</div>

</div>

<div class="profile">

</div>

</div>

</body>
</html>