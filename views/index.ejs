<!doctype html>
<html>
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-gradient-to-br from-[#020617] via-[#0f172a] to-[#022c22] text-slate-200 overflow-x-hidden">

<!-- Navbar -->
<nav class="bg-[#020617]/80 backdrop-blur-lg border-b border-cyan-400/20 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">

    <h1 class="text-3xl font-semibold tracking-wide text-cyan-400">
      JungleX
    </h1>

    <div class="hidden md:flex items-center gap-8 text-sm uppercase tracking-wider text-slate-300">
      <a href="#" class="hover:text-cyan-400 transition">Home</a>
      <a href="#" class="hover:text-cyan-400 transition">Adventure</a>
      <a href="#" class="hover:text-cyan-400 transition">Wildlife</a>
      <a href="#" class="hover:text-cyan-400 transition">Gallery</a>
    </div>

    <a href="/login">
      <button class="bg-cyan-400 text-black px-5 py-2 rounded-md font-medium hover:bg-cyan-300 transition">
        Login
      </button>
    </a>

  </div>
</nav>

<!-- Hero -->
<section class="relative min-h-screen flex items-center">

  <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-10 items-center">

    <!-- Left -->
    <div>
      <p class="uppercase tracking-[8px] text-cyan-400 mb-4 text-xs">
        Explore Nature
      </p>

      <h2 class="text-6xl md:text-7xl font-semibold leading-tight mb-6">
        INTO THE <span class="text-cyan-400">WILD</span>
      </h2>

      <p class="text-slate-300 text-lg leading-relaxed mb-8 max-w-xl">
        Step into deep forests, hidden rivers, and raw jungle energy.
        Discover an unforgettable world where adventure never sleeps.
      </p>

      <div class="flex gap-4">
        <button class="bg-cyan-400 text-black px-7 py-3 rounded-md font-semibold hover:bg-cyan-300 transition">
          Start Journey
        </button>

        <button class="border border-cyan-400 px-7 py-3 rounded-md hover:bg-cyan-400 hover:text-black transition">
          Learn More
        </button>
      </div>
    </div>

    <!-- Right -->
    <div class="relative flex justify-center">

      <div class="absolute w-[420px] h-[420px] bg-cyan-400/10 rounded-full blur-3xl"></div>

      <img
        src="https://images.unsplash.com/photo-1448375240586-882707db888b"
        class="relative w-[420px] h-[520px] object-cover rounded-xl border border-white/10 shadow-xl hover:scale-105 transition duration-500"
      />

      <div class="absolute bottom-6 left-0 bg-[#020617]/70 backdrop-blur-md border border-white/10 px-5 py-3 rounded-lg">
        <p class="text-xs text-cyan-400">Live Adventure</p>
        <h4 class="font-semibold">Rainforest Tours</h4>
      </div>

    </div>

  </div>
</section>

<!-- Cards -->
<section class="pb-20">
  <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-3 gap-8">

    <div class="bg-white/5 backdrop-blur-lg border border-white/10 p-8 rounded-xl hover:bg-cyan-400/10 transition duration-300">
      <h3 class="text-2xl font-semibold text-cyan-400 mb-4">Dense Forest</h3>
      <p class="text-slate-300">
        Walk through lush green forests filled with mystery and beauty.
      </p>
    </div>

    <div class="bg-white/5 backdrop-blur-lg border border-white/10 p-8 rounded-xl hover:bg-cyan-400/10 transition duration-300">
      <h3 class="text-2xl font-semibold text-cyan-400 mb-4">Hidden Falls</h3>
      <p class="text-slate-300">
        Discover secret waterfalls deep inside untouched nature.
      </p>
    </div>

    <div class="bg-white/5 backdrop-blur-lg border border-white/10 p-8 rounded-xl hover:bg-cyan-400/10 transition duration-300">
      <h3 class="text-2xl font-semibold text-cyan-400 mb-4">Wild Safari</h3>
      <p class="text-slate-300">
        Experience wildlife adventures and thrilling jungle nights.
      </p>
    </div>

  </div>
</section>

<!-- Footer -->
<footer class="border-t border-white/10 py-6 text-center text-slate-400">
  © 2026 JungleX • Nature Lives Here
</footer>

</body>
</html>