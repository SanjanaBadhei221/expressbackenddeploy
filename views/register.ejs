<!doctype html>
<html>
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="min-h-screen bg-gradient-to-br from-green-950 via-green-900 to-lime-900 flex items-center justify-center px-4 py-10">

<!-- Glow Background -->
<div class="absolute top-10 left-10 w-72 h-72 bg-lime-400/20 rounded-full blur-3xl"></div>
<div class="absolute bottom-10 right-10 w-80 h-80 bg-green-400/20 rounded-full blur-3xl"></div>

<!-- Register Card -->
<div class="relative z-10 w-full max-w-md bg-white/10 backdrop-blur-xl border border-white/10 rounded-[30px] shadow-2xl p-8">

  <!-- Heading -->
  <div class="text-center mb-8">
    <h2 class="text-4xl font-black text-lime-300 tracking-wide">
      Join JungleX
    </h2>
    <p class="text-green-100 mt-2">
      Become Part of the Wild Tribe
    </p>
  </div>

  <!-- Form -->
  <form action="/registerform" method="POST" class="space-y-4">

    <div>
      <label class="block text-sm text-lime-200 mb-2">Username</label>
      <input type="text" name="username" required
      class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/10 text-white outline-none placeholder-green-200 focus:border-lime-400">
    </div>

    <div>
      <label class="block text-sm text-lime-200 mb-2">Age</label>
      <input type="number" name="age" required
      class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/10 text-white outline-none focus:border-lime-400">
    </div>

    <div>
      <label class="block text-sm text-lime-200 mb-2">Email</label>
      <input type="email" name="email" required
      class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/10 text-white outline-none placeholder-green-200 focus:border-lime-400">
    </div>

    <div>
      <label class="block text-sm text-lime-200 mb-2">Role</label>
      <input type="text" name="role" placeholder="user/admin" required
      class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/10 text-white outline-none placeholder-green-200 focus:border-lime-400">
    </div>

    <div>
      <label class="block text-sm text-lime-200 mb-2">Password</label>
      <input type="password" name="password" required
      class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/10 text-white outline-none placeholder-green-200 focus:border-lime-400">
    </div>

    <div>
      <label class="block text-sm text-lime-200 mb-2">Confirm Password</label>
      <input type="password" name="confirmPassword" required
      class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/10 text-white outline-none placeholder-green-200 focus:border-lime-400">
    </div>

    <button
      type="submit"
      class="w-full bg-lime-400 text-black py-3 rounded-xl font-bold hover:scale-105 transition duration-300 mt-2">
      Register Now
    </button>

  </form>

  <!-- Footer -->
  <p class="text-center text-green-100 text-sm mt-6">
    Already have an account?
    <a href="/login" class="text-lime-300 font-semibold hover:underline">
      Login
    </a>
  </p>

</div>

</body>
</html>