<!doctype html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <title>Shopping Page</title>
</head>

<body class="bg-gray-100">

  <!-- Navbar -->
  <nav class="bg-white shadow-md p-4 flex justify-between">
    <h1 class="text-xl font-bold text-teal-600">MyStore</h1>
    <a href="/" class="text-gray-700 hover:text-teal-600">Home</a>
  </nav>

  <!-- Heading -->
  <div class="text-center mt-8">
    <h2 class="text-3xl font-bold">Shop Products 🛒</h2>
    <p class="text-gray-600 mt-2">Choose your favorite items</p>
  </div>

  <!-- Products -->
  <div class="max-w-6xl mx-auto px-6 py-10 grid md:grid-cols-3 gap-8">

    <% items.forEach(item => { %>
      <div class="bg-white p-5 rounded-xl shadow hover:shadow-lg transition">

        <img 
          src="<%= item.image %>" 
          class="w-full h-48 object-cover rounded-lg mb-4"
        />

        <h3 class="text-lg font-semibold"><%= item.name %></h3>
        <p class="text-gray-600 mb-3">₹ <%= item.price %></p>

        <button class="bg-teal-600 text-white px-4 py-2 rounded-lg hover:bg-teal-700">
          Buy Now
        </button>

      </div>
    <% }) %>

  </div>

</body>
</html>